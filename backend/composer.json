{
    "name": "marekskopal/ukolio",
    "type": "project",
    "description": "Ukolio",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "ext-filter": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "async-aws/s3": "^3.3",
        "contributte/redis": "^0.6.0",
        "dragonmantank/cron-expression": "^3.6",
        "firebase/php-jwt": "^7.0",
        "laminas/laminas-diactoros": "^3.3",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "league/container": "^5.0",
        "league/route": "^6.1",
        "marekskopal/orm": "^1.0",
        "marekskopal/orm-migrations": "^1.0",
        "marekskopal/router": "^1.1",
        "mcp/sdk": "^0.6.0",
        "meilisearch/meilisearch-php": "^1.16",
        "nette/caching": "^3.3",
        "nette/utils": "^4.0",
        "nyholm/psr7": "^1.8",
        "php-amqplib/php-amqplib": "^3.7",
        "php-http/discovery": "^1.19",
        "predis/predis": "^2.3",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0",
        "symfony/console": "^8.0",
        "symfony/finder": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/mailer": "^8.0",
        "symfony/mercure": "^0.7.2",
        "symfony/mime": "^8.0",
        "tracy/tracy": "^2.10"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0",
        "shipmonk/phpstan-rules": "^4.0",
        "slevomat/coding-standard": "^8.14",
        "tomasvotruba/cognitive-complexity": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Ukolio\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ukolio\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.5"
        },
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    }
}
