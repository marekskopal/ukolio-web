{
    "name": "marekskopal/task-manager",
    "type": "project",
    "description": "Task Manager",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "ext-filter": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "firebase/php-jwt": "^7.0",
        "laminas/laminas-diactoros": "^3.3",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "league/container": "^5.0",
        "league/route": "^6.1",
        "marekskopal/orm": "^1.0",
        "marekskopal/orm-migrations": "^1.0",
        "marekskopal/router": "^1.1",
        "nette/caching": "^3.3",
        "nette/utils": "^4.0",
        "nyholm/psr7": "^1.8",
        "php-http/discovery": "^1.19",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "symfony/console": "^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "TaskManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TaskManager\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.5"
        },
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
