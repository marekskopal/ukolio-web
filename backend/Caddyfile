{
	auto_https off
	servers {
		trusted_proxies static private_ranges
	}
	order mercure after encode
}

:80 {
	encode zstd gzip

	mercure {
		publisher_jwt {$MERCURE_PUBLISHER_JWT_KEY} HS256
		subscriber_jwt {$MERCURE_SUBSCRIBER_JWT_KEY} HS256
		cors_origins {$BACKEND_CORS_ALLOWED_ORIGIN:*}
		anonymous
	}

	php {
		root /app/src
		worker {
			file frankenphp-worker.php
			num {$BACKEND_FRANKENPHP_WORKERS:4}
			match *
		}
	}
}
