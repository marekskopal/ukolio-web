<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="default">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
    <!--
        Coverage focuses on the seams called out in UPB-49 acceptance criteria.
        DTOs, entities, repositories, etc. are not in scope and would dilute the metric.
    -->
    <source>
        <include>
            <directory>src/Controller</directory>
            <directory>src/Mcp</directory>
            <directory>src/Service</directory>
            <directory>src/OAuth</directory>
            <directory>src/Validator</directory>
        </include>
    </source>
</phpunit>
