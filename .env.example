# `development` (default) or `production`. When set to `production` the backend
# refuses to boot with the default MYSQL/S3 credentials or short secrets — see
# README for `openssl rand -hex 32` instructions.
APP_ENV=development
PROXY_HOST=localhost
PROXY_PORT=4300
PROXY_PORT_SSL=7281
PROXY_SSL_CERT=
PROXY_SSL_KEY=
MYSQL_HOST=db
MYSQL_DATABASE=ukolio
MYSQL_USER=ukolio
MYSQL_ROOT_PASSWORD=ukolio
MYSQL_PASSWORD=ukolio
AUTHORIZATION_TOKEN_KEY=replace-with-32-char-random-hex-key-here
# Google OAuth — leave empty to disable the "Sign in with Google" button on the
# login page. Obtain a web client ID at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
BACKEND_FRANKENPHP_WORKERS=4
# Allowed Origin(s) for cross-origin browser calls to /api/* and the Mercure
# hub. `*` is fine for local dev. With APP_ENV=production the backend refuses
# to boot on `*` — set an explicit list (separate multiple origins with spaces
# or commas, e.g. `https://app.example.com https://staging.example.com`).
BACKEND_CORS_ALLOWED_ORIGIN=*
BACKEND_LOG_LEVEL=production
ADMINER_USER=
ADMINER_PASSWORD=
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@ukolio.local
APP_URL=http://localhost:4300
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=ukolio-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true
TASK_FILE_MAX_SIZE_MB=25
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ukolio
MEMCACHED_HOST=memcached
MEMCACHED_PORT=11211
# RabbitMQ — drives async email delivery via the supervisor-managed amqp-consumer
# inside the backend container.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=ukolio
RABBITMQ_PASSWORD=ukolio
# Per-queue prefetch (basic_qos) for the consumer — caps in-flight unacked messages per channel.
BACKEND_AMQP_CONSUMER_PREFETCH=10
MCP_SESSION_TTL=86400
# Failed-login backoff: after N consecutive failures on the same account, the
# account is temporarily locked. Backoff doubles with each subsequent failure
# (60s, 120s, 300s, 900s, 1800s) and tops out at RATE_LIMIT_LOGIN_BACKOFF_CAP_SECONDS.
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_BACKOFF_CAP_SECONDS=3600
# Max invitations a single workspace can create in a rolling 1-hour window.
RATE_LIMIT_INVITATIONS_PER_HOUR=50
# Mercure (realtime SSE hub embedded in FrankenPHP/Caddy). Replace with long random secrets in production.
MERCURE_PUBLISHER_JWT_KEY=replace-with-32-char-random-hex-key-here
MERCURE_SUBSCRIBER_JWT_KEY=replace-with-32-char-random-hex-key-here
MERCURE_PUBLISH_URL=http://localhost/.well-known/mercure
