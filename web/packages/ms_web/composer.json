{
    "name": "marekskopal/typo3-web",
    "type": "typo3-cms-extension",
    "require": {
        "typo3/cms-core": "^14.3.0"
    },
    "autoload": {
        "psr-4": {
            "MarekSkopal\\MsWeb\\": "Classes/"
        }
    },
    "replace": {
        "ms_web": "self.version"
    },
    "extra": {
